# ── CLIENT-SIDE (browser-accessible) ──────────────────────────
# Supabase — get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# Facility ID — the UUID of this specific facility from your facilities table
NEXT_PUBLIC_FACILITY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# App URL — used for generating discharge report download links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── SERVER-SIDE ONLY (never sent to browser) ──────────────────
# Supabase service role — get from: Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# JWT secret — generate with: openssl rand -base64 64
JWT_SECRET=paste_your_64_character_random_string_here

# Anthropic — get from: console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Gemini API Key (AI Studio runtime)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
